# ==========================================
# SAPA LPPM Production Environment Example
# ==========================================

CI_ENVIRONMENT=production

# App
APP_NAME="SAPA LPPM"
APP_URL="https://sapa.unisap.ac.id"
app.baseURL="https://sapa.unisap.ac.id/"
app.forceGlobalSecureRequests=true
APP_TIMEZONE="Asia/Makassar"

# Rate limit
RATE_LIMIT_USERS_DOSEN_DELETE_MAX="40"
RATE_LIMIT_USERS_DOSEN_DELETE_WINDOW="300"
RATE_LIMIT_USERS_DOSEN_BULK_DELETE_MAX="10"
RATE_LIMIT_USERS_DOSEN_BULK_DELETE_WINDOW="300"
RATE_LIMIT_SETTINGS_CONTRACT_DELETE_MAX="30"
RATE_LIMIT_SETTINGS_CONTRACT_DELETE_WINDOW="300"

# Database
DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="your_database_name"
DB_USERNAME="your_database_user"
DB_PASSWORD="your_database_password"
DB_CHARSET="utf8mb4"

# Email / SMTP
MAIL_FROM_ADDRESS="your-mail@domain.com"
MAIL_FROM_NAME="SAPA LPPM Universitas San Pedro"
MAIL_RECIPIENTS=""
MAIL_PROTOCOL="smtp"
MAIL_SMTP_HOST="smtp.your-provider.com"
MAIL_SMTP_AUTH_METHOD="login"
MAIL_SMTP_USER="your-mail@domain.com"
MAIL_SMTP_PASS="your_smtp_password"
MAIL_SMTP_PORT="465"
MAIL_SMTP_TIMEOUT="15"
MAIL_SMTP_CRYPTO="ssl"
MAIL_TYPE="html"
MAIL_CHARSET="UTF-8"
MAIL_VALIDATE="true"
MAIL_WORD_WRAP="true"
